; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="dust_diesel"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

Nakama="*res://addons/com.heroiclabs.nakama/Nakama.gd"
NakamaManager="*res://scripts/network/nakama_manager.gd"
GameState="*res://scripts/autoloads/GameState.gd"
VehicleRegistry="*res://scripts/car/vehicle_registry.gd"
MapRegistry="*res://scripts/game/map_registry.gd"
PhantomCameraManager="*uid://duq6jhf6unyis"

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg")

